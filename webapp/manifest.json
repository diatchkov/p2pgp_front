{
  "_version": "1.60.0",
  "sap.app": {
    "id": "ae.emsteel.asas.p2pgp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.18.2",
      "toolsId": "c04016b5-6fb0-4c04-9894-7ff8d555602c"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zp2p_ui_gp_o4/srvd/sap/zp2p_ui_gp/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.23",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ae.emsteel.asas.p2pgp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "flexibleColumnLayout": {
          "defaultTwoColumnLayoutType": "TwoColumnsMidExpanded",
          "defaultThreeColumnLayoutType": "ThreeColumnsEndExpanded"
        },
        "routerClass": "sap.f.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ZC_P2P_INBGATEPASSList",
          "target": [
            "ZC_P2P_INBGATEPASSList"
          ]
        },
        {
          "pattern": "ZC_P2P_INBGATEPASS({key}):?query:",
          "name": "ZC_P2P_INBGATEPASSObjectPage",
          "target": [
            "ZC_P2P_INBGATEPASSList",
            "ZC_P2P_INBGATEPASSObjectPage"
          ]
        },
        {
          "pattern": "ZC_P2P_INBGATEPASS({key})/_Item({key2}):?query:",
          "name": "ZC_P2P_INBGATEPASSITEMObjectPage",
          "target": [
            "ZC_P2P_INBGATEPASSList",
            "ZC_P2P_INBGATEPASSObjectPage",
            "ZC_P2P_INBGATEPASSITEMObjectPage"
          ]
        },
        {
          "name": "ZC_P2P_OTBGATEPASSObjectPage",
          "pattern": "ZC_P2P_OTBGATEPASS({key}):?query:",
          "target": [
            "ZC_P2P_INBGATEPASSList",
            "ZC_P2P_OTBGATEPASSObjectPage"
          ]
        },
        {
          "name": "ZC_P2P_OTBGATEPASSItemObjectPage",
          "pattern": "ZC_P2P_OTBGATEPASS({key})/_Item({key2}):?query:",
          "target": [
            "ZC_P2P_INBGATEPASSList",
            "ZC_P2P_OTBGATEPASSObjectPage",
            "ZC_P2P_OTBGATEPASSItemObjectPage"
          ]
        }
      ],
      "targets": {
        "ZC_P2P_INBGATEPASSList": {
          "type": "Component",
          "id": "ZC_P2P_INBGATEPASSList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ZC_P2P_INBGATEPASS",
              "variantManagement": "Page",
              "navigation": {
                "ZC_P2P_INBGATEPASS": {
                  "detail": {
                    "route": "ZC_P2P_INBGATEPASSObjectPage"
                  }
                },
                "ZC_P2P_OTBGATEPASS": {
                  "detail": {
                    "route": "ZC_P2P_OTBGATEPASSObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "views": {
                "paths": [
                  {
                    "key": "tab0",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#SPVInbGatePass",
                    "entitySet": "ZC_P2P_INBGATEPASS"
                  },
                  {
                    "key": "tab1",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#SPVOtbGatePass",
                    "entitySet": "ZC_P2P_OTBGATEPASS"
                  }
                ],
                "showCounts": true
              },
              "content": {
                "header": {
                  "actions": {
                    "SetWBID": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.WBID.set",
                      "visible": true,
                      "enabled": true,
                      "text": "{i18n>setWeighbridgeId}"
                    }
                  }
                }
              }
            }
          },
          "controlAggregation": "beginColumnPages",
          "contextPattern": ""
        },
        "ZC_P2P_INBGATEPASSObjectPage": {
          "type": "Component",
          "id": "ZC_P2P_INBGATEPASSObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZC_P2P_INBGATEPASS",
              "navigation": {
                "_Item": {
                  "detail": {
                    "route": "ZC_P2P_INBGATEPASSITEMObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "_Item/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "createAtEnd": true,
                      "name": "Inline"
                    }
                  },
                  "actions": {
                    "InbNotePrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.InbNote.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printDeliveryNote}"
                    }
                  }
                },
                "_PO/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "createAtEnd": true,
                      "name": "Inline"
                    }
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "InbGPEntryPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.GPEntry.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "{@i18n>printEntry}",
                      "position": {
                        "anchor": "DeleteAction",
                        "placement": "After"
                      }
                    },
                    "InbGPExitPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.GPExit.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "{@i18n>printExit}",
                      "position": {
                        "anchor": "InbGPEntryPrint",
                        "placement": "After"
                      }
                    }
                  }
                }
              }
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/ZC_P2P_INBGATEPASS({key})"
        },
        "ZC_P2P_INBGATEPASSITEMObjectPage": {
          "type": "Component",
          "id": "ZC_P2P_INBGATEPASSITEMObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZC_P2P_INBGATEPASS/_Item"
            }
          },
          "controlAggregation": "endColumnPages",
          "contextPattern": "/ZC_P2P_INBGATEPASS({key})/_Item({key2})"
        },
        "ZC_P2P_OTBGATEPASSObjectPage": {
          "type": "Component",
          "id": "ZC_P2P_OTBGATEPASSObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "navigation": {
                "_Item": {
                  "detail": {
                    "route": "ZC_P2P_OTBGATEPASSItemObjectPage"
                  }
                }
              },
              "contextPath": "/ZC_P2P_OTBGATEPASS",
              "controlConfiguration": {
                "_Item/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "createAtEnd": true,
                      "name": "Inline"
                    }
                  },
                  "actions": {
                    "OtbNotePrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.OtbNote.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printDeliveryNote}"
                    },
                    "OtbQualCertPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.OtbQualCert.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printQualCert}"
                    },
                    "OtbTaxInvPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.OtbTaxInv.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printTaxInv}"
                    },
                    "OtbAdvInvPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.OtbAdvInv.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printAdvInv}"
                    },
                    "OtbPlanNotePrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.OtbPlanNote.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "{i18n>printPlanNote}",
                      "position": {
                        "placement": "After",
                        "anchor": "OtbNotePrint"
                      }
                    }
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "OtbGPEntryPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.GPEntry.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "{@i18n>printEntry}",
                      "position": {
                        "anchor": "DeleteAction",
                        "placement": "After"
                      }
                    },
                    "OtbGPExitPrint": {
                      "press": "ae.emsteel.asas.p2pgp.ext.controller.GPExit.Print",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "{@i18n>printExit}",
                      "position": {
                        "anchor": "OtbGPEntryPrint",
                        "placement": "After"
                      }
                    }
                  }
                }
              }
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/ZC_P2P_OTBGATEPASS({key})"
        },
        "ZC_P2P_OTBGATEPASSItemObjectPage": {
          "type": "Component",
          "id": "ZC_P2P_OTBGATEPASSItemObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZC_P2P_OTBGATEPASS/_Item"
            }
          },
          "controlAggregation": "endColumnPages",
          "contextPattern": "/ZC_P2P_OTBGATEPASS({key})/_Item({key2})"
        }
      }
    },
    "rootView": {
      "viewName": "sap.fe.templates.RootContainer.view.Fcl",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    },
    
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController#ae.emsteel.asas.p2pgp::ZC_P2P_INBGATEPASSList": {
            "controllerName": "ae.emsteel.asas.p2pgp.ext.controller.ListReportExt"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
